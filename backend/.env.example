# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase JWT secret — found in Supabase Dashboard > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase PostgreSQL connection string
# Found in Supabase Dashboard > Project Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# CORS — comma-separated, no trailing slashes
ALLOWED_ORIGINS=http://localhost:5173,https://ats-resume-analyzer.vercel.app

# Render sets PORT automatically; leave this for local dev
PORT=8080
